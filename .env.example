# =============================================================================
# FintelliAI — environment template (NO real secrets — copy and fill locally)
# =============================================================================
#
# Local dev:
#   cp .env.example backend/.env
#   cp frontend/.env.local.example frontend/.env.local
#
# Production (Vercel + Render, ONE shared Postgres):
#   1. Create Render Postgres → copy External Database URL
#   2. Paste SAME DATABASE_URL into Render (backend) AND Vercel (frontend)
#   3. See DEPLOY.md for full checklist
#
# NEVER commit files with real values: backend/.env, frontend/.env.local

# ─── Shared PostgreSQL (Django ORM + Prisma) ─────────────────────────────────
# Render: Dashboard → Postgres → Connections → External Database URL
# Add ?sslmode=require if your client requires it (Prisma usually handles SSL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fintelli?sslmode=require

# ─── Django backend (Render web service) ───────────────────────────────────────
DJANGO_SECRET_KEY=generate-with-openssl-rand-hex-32
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-api.onrender.com
DATABASE_SSL=true

NEWSAPI_KEY=
FINNHUB_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ALPHA_VANTAGE_API_KEY=

# ─── Microsoft Foundry (Reasoning Agents challenge) ───────────────────────────
# Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=
# Azure OpenAI compatible endpoint + key (used for agent LLM calls)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
# Option: Individual project settings (managed identity)
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_AI_PROJECT_NAME=

# Optional Microsoft Learn MCP server
MCP_LEARN_ENABLED=false
MCP_LEARN_SERVER_URL=

FEATURE_GENAI_INSIGHTS=true
FEATURE_AGENTS=true
FEATURE_QUANT_SIGNALS=true
FEATURE_WEBSOCKETS=true

# Comma-separated frontend origin(s)
CORS_EXTRA_ORIGINS=https://your-app.vercel.app

# Optional — skip on Render free tier (app uses in-memory cache/channels)
# REDIS_URL=
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Next.js frontend (Vercel) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://your-api.onrender.com

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.vercel.app
DASHBOARD_PASSWORD=choose-a-demo-password

OPENAI_API_KEY=
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
EDGE_BROKER=ZERODHA
